{
  "schema": {
    "https://test.ujoo.fr/graphql": {
      "headers": {
        "Authorization": "Bearer xzy"
      }
    }
  },
  "generates": {
    "./framework/magento2/schema.d.ts": {
      "plugins": ["typescript", "typescript-operations"]
    },
    "./framework/magento2/schema.graphql": {
      "plugins": ["schema-ast"]
    }
  },
  "hooks": {
    "afterAllFileWrite": ["prettier --write"]
  }
}
